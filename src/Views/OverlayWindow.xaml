<Window x:Class="WinLens.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinLens Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Opacity="0">
    <Grid>
        <Image x:Name="BackgroundImage" Stretch="Fill"/>
        <Canvas x:Name="OverlayCanvas" Background="#01000000"/>

        <!-- Floating control bar -->
        <Border x:Name="TopBar"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,16,0,0"
                CornerRadius="12" Padding="14,8"
                Background="#F01A1D24"
                BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="22" ShadowDepth="4" Opacity="0.5"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="22" Height="22" CornerRadius="6"
                        Background="{StaticResource AccentGradient}" Margin="0,0,10,0">
                    <Viewbox Width="13" Height="13">
                        <Canvas Width="24" Height="24">
                            <Ellipse Canvas.Left="3" Canvas.Top="3" Width="13" Height="13"
                                     Stroke="White" StrokeThickness="2.2"/>
                            <Line X1="14" Y1="14" X2="21" Y2="21" Stroke="White" StrokeThickness="2.2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Viewbox>
                </Border>
                <TextBlock Text="WinLens" Foreground="{StaticResource TextBrush}"
                           FontFamily="Segoe UI" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                <ComboBox x:Name="LanguageBox" Width="150" Height="34"
                          Style="{StaticResource ModernComboBox}"
                          VerticalAlignment="Center"
                          SelectionChanged="OnLanguageChanged"/>
                <TextBlock Text="Esc to close" Foreground="{StaticResource TextFaintBrush}"
                           FontFamily="Segoe UI" FontSize="11"
                           VerticalAlignment="Center" Margin="14,0,4,0"/>
                <Button x:Name="CloseBtn" Content="Close" Height="34"
                        Style="{StaticResource SecondaryButton}"
                        Margin="8,0,0,0" Click="OnCloseClick"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
